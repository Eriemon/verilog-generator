  "fpga_developer_routing": {
    "state_path": ".erie-verilog-generator-state/dependency-state.json",
    "selection_policy": "ask_on_first_fpga_workflow",
    "persist_selection": true,
    "fpga_agent_required_when_developer_present": false,
    "vendors": {
      "amd_xilinx": {
        "label": "AMD-Xilinx",
        "skills": [
          "vivado-developer",
          "vitis-developer"
        ]
      },
      "pangomicro": {
        "label": "PangoMicro",
        "skills": [
          "pds-developer"
        ]
      }
    }
  },
  "workflow": {
    "mode": "generate",
    "target": "rtl",
    "readiness": "static",
    "max_attempts": 3,
    "comment_language": "zh",
    "model_provider": "command",
    "stop_on_human": true,
    "run_external": true,
    "model_timeout_s": 120
  },
  "policy": {
    "local_static_allowed": true,
    "allow_implicit_local_external_validation": false,
    "prefer_remote_for_external_validation": true,
    "block_when_remote_unconfigured": true
  },
  "validation": {
    "local_readiness": "static",
    "remote_readiness": "execute",
    "blocked_implement_readiness": "implement",
    "external_tools": [
      "xvlog",
      "xelab",
      "xsim",
      "vcs",
      "verdi",
      "iverilog",
      "vvp",
      "yosys"
    ],
    "simulators": {
      "selection_policy": "fallback",
      "priority": [
        "xsim",
        "vcs_verdi",
        "iverilog"
      ],
      "backends": {
        "xsim": {
          "tools": [
            "xvlog",
            "xelab",
            "xsim"
          ]
        },
        "vcs_verdi": {
          "tools": [
            "vcs",
            "verdi"
          ]
        },
        "iverilog": {
          "tools": [
            "iverilog",
            "vvp"
          ]
        }
      }
    },
    "legacy_term_allowlist": [
      "ENGINEERING_DESIGN_GOALS.md"
    ],
    "forbidden_residuals": [
      "__pycache__",
      "_smoke_runs",
      "workflow-state.json"
    ]
  },
  "remote": {
    "integration": {
      "remote_ssh_helper": "${home}/.codex/skills/erie-remote-ssh/scripts/remote_ssh.py",
      "remote_ssh_settings": "${home}/.codex/skills/erie-remote-ssh/assets/defaults.json",
      "selection_file": ".settings/remote-selection.local.json",
      "server_list": ".settings/server_list.local.json",
      "remote_runtime_config": ".settings/verilog.remote.json"
    },
    "python": "python3",
    "remote_root": ".erie-verilog-generator-validation",
    "timeout_s": 120
  }
}
