{
  "name": "spi_adc_capture_bridge",
  "target": "rtl",
  "rtl_dialect": "verilog",
  "rtl_style_profile": "erie_strict",
  "design_requirements": {
    "target": "rtl",
    "pipeline_required": true,
    "streamability": "streamable",
    "interface_family": "native",
    "interface_profile": {},
    "confirmed_by_user": true,
    "confirmation_notes": "Use the SPI ADC family template for a triggered sample capture bridge."
  },
  "streamability": "streamable",
  "interface_family": "native",
  "interface_profile": {},
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Bridge a triggered SPI ADC capture engine to a one-sample-valid output with explicit conversion launch and BUSY handling.",
  "interfaces": {
    "ports": [
      {
        "name": "i_clk",
        "direction": "input",
        "width": 1,
        "role": "clock"
      },
      {
        "name": "i_rstn",
        "direction": "input",
        "width": 1,
        "role": "reset"
      },
      {
        "name": "i_trigger",
        "direction": "input",
        "width": 1
      },
      {
        "name": "i_busy",
        "direction": "input",
        "width": 1
      },
      {
        "name": "i_spi_sdo",
        "direction": "input",
        "width": 1
      },
      {
        "name": "o_spi_sclk",
        "direction": "output",
        "width": 1
      },
      {
        "name": "o_spi_cnv",
        "direction": "output",
        "width": 1
      },
      {
        "name": "o_sample_valid",
        "direction": "output",
        "width": 1
      },
      {
        "name": "o_sample_data",
        "direction": "output",
        "width": 16
      }
    ]
  },
  "behavior": [
    "Launch a conversion when i_trigger is asserted.",
    "Capture one 16-bit sample when BUSY deasserts.",
    "Assert o_sample_valid for one cycle per completed conversion."
  ],
  "clock": {
    "name": "i_clk",
    "edge": "posedge",
    "frequency_mhz": 100
  },
  "reset": {
    "name": "i_rstn",
    "active": "low",
    "synchronous": false
  },
  "constraints": [
    "Use synthesizable Verilog-2001.",
    "Keep conversion launch and sample capture timing reviewable."
  ],
  "outputs": [
    {
      "path": "rtl/spi_adc_capture_bridge.v",
      "kind": "source",
      "language": "verilog"
    },
    {
      "path": "tb/spi_adc_capture_bridge_tb.v",
      "kind": "testbench",
      "language": "verilog"
    }
  ],
  "notes": [],
  "subfunctions": [],
  "workflow": {
    "use_case_template_id": "spi_adc"
