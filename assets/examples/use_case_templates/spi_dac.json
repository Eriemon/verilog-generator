      {
        "name": "i_sample_data",
        "direction": "input",
        "width": 16
      },
      {
        "name": "o_spi_sclk",
        "direction": "output",
        "width": 1
      },
      {
        "name": "o_spi_sync_n",
        "direction": "output",
