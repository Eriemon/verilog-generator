    "confirmation_notes": "Remote confidence fixture for sequential pipeline RTL."
  },
  "streamability": "non_streamable",
  "interface_family": "native",
  "interface_profile": {},
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Delay an 8-bit sample and valid bit by one clock cycle.",
  "interfaces": {
    "ports": [
      {
        "name": "i_clk",
        "direction": "input",
        "width": 1,
        "role": "clock"
      },
      {
        "name": "i_rstn",
        "direction": "input",
        "width": 1,
        "role": "reset"
      },
      {
        "name": "i_valid",
        "direction": "input",
        "width": 1
      },
      {
        "name": "i_data",
        "direction": "input",
        "width": 8
      },
      {
        "name": "o_valid",
        "direction": "output",
        "width": 1
      },
      {
        "name": "o_data",
        "direction": "output",
        "width": 8
      }
    ]
  },
  "behavior": [
    "Clear outputs during reset.",
    "On each rising clock edge after reset, forward i_valid and i_data to the outputs."
  ],
  "clock": {
    "name": "i_clk",
    "edge": "posedge",
    "frequency_mhz": 100
  },
  "reset": {
    "name": "i_rstn",
    "active": "low",
    "synchronous": false
  },
  "constraints": [
    "Use synthesizable Verilog-2001.",
    "Use a single clocked always block."
  ],
  "outputs": [
    {
      "path": "rtl/pipeline_delay.v",
      "kind": "source",
